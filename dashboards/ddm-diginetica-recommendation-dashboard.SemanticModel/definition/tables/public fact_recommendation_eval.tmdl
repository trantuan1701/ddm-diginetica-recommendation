	column 'Session Length Bucket (Fixed)' =
			SWITCH(TRUE(),
			    'public fact_recommendation_eval'[target_item_view_count] <= 3, "1-3",
			    'public fact_recommendation_eval'[target_item_view_count] <= 5, "4-5",
			    'public fact_recommendation_eval'[target_item_view_count] <= 9, "6-9",
			    'public fact_recommendation_eval'[target_item_view_count] <= 20, "10-20",
			    "20+"
			)
		dataType: string
		lineageTag: 1dc8884a-4c05-428a-8727-725db5f25687
		summarizeBy: none
		sortByColumn: 'Session Length Bucket Sort'

		annotation SummarizationSetBy = Automatic

	column 'Session Length Bucket Sort' =
			SWITCH(TRUE(),
			    'public fact_recommendation_eval'[target_item_view_count] <= 3, 1,
			    'public fact_recommendation_eval'[target_item_view_count] <= 5, 2,
			    'public fact_recommendation_eval'[target_item_view_count] <= 9, 3,
			    'public fact_recommendation_eval'[target_item_view_count] <= 20, 4,
