	measure 'CR (Views 1-5)' = CALCULATE([Conversion Rate], KEEPFILTERS('public dim_session'[total_views] >= 1), KEEPFILTERS('public dim_session'[total_views] <= 5))
		formatString: 0.00%
		displayFolder: 'Graph Page 2'
		lineageTag: 38619f7a-a25e-48ef-bf10-8c2757cc8d82

