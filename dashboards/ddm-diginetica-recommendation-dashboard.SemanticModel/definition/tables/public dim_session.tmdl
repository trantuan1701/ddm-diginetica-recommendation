table 'public dim_session'
	lineageTag: 0d3297b9-ec1c-4de9-b5f9-1aa05b57ca99

	measure 'Total Sessions' = DISTINCTCOUNT('public dim_session'[session_id])
		formatString: #,0
		displayFolder: 'KPI Page 1'
		lineageTag: aeedf588-70a1-476c-a7aa-342d0e9013be

	measure 'Purchasing Sessions' = CALCULATE([Total Sessions], KEEPFILTERS('public dim_session'[has_purchase] = TRUE()))
		formatString: #,0
		displayFolder: 'KPI Page 1'
		lineageTag: 9dd6b868-cfe9-401e-bf03-52fb69459cf1

	measure 'Conversion Rate' = DIVIDE([Purchasing Sessions], [Total Sessions])
		formatString: 0.00%
		displayFolder: 'KPI Page 1'
		lineageTag: 9fc6b4f8-4e5b-4bcf-b392-0bda868acaa9

	measure 'Avg Session Depth' = AVERAGE('public dim_session'[total_views])
		formatString: 0.00
		displayFolder: 'KPI Page 2'
		lineageTag: 61f81b1b-aa89-44af-9b1b-94670818cae4

	measure 'Bounce Sessions' = CALCULATE([Total Sessions], KEEPFILTERS('public dim_session'[total_views] <= 1))
		formatString: #,0
		displayFolder: 'KPI Page 2'
		lineageTag: edefb406-739b-4716-a484-c9b1fea9a5a5

	measure 'Bounce Rate' = DIVIDE([Bounce Sessions], [Total Sessions])
		formatString: 0.00%
		displayFolder: 'KPI Page 2'
		lineageTag: 56729c66-4215-4547-beb5-592ee5e7c569

	measure 'Avg Session Duration (min)' = AVERAGEX(VALUES('public dim_session'[session_id]), VAR _min_tf = CALCULATE(MIN('public fact_item_views'[timeframe])) VAR _max_tf = CALCULATE(MAX('public fact_item_views'[timeframe])) RETURN DIVIDE(_max_tf - _min_tf, 60.0))
		formatString: 0.00
		displayFolder: 'KPI Page 2'
		lineageTag: 57ab7992-838e-41fd-a73b-f3cc282691fe

	measure 'Anonymous Sessions' = CALCULATE([Total Sessions], KEEPFILTERS('public dim_session'[session_type] = "anonymous"))
		formatString: #,0
		displayFolder: 'Graph Page 1'
		lineageTag: 4e20b2d2-fab9-4cd6-adbc-9e276d62bff7

	measure 'Identified Sessions' = [Total Sessions] - [Anonymous Sessions]
		formatString: #,0
		displayFolder: 'Graph Page 1'
		lineageTag: bf5ee1f0-510d-4535-a6c1-37a7da60931a

	measure 'Percent Anonymous Sessions' = DIVIDE([Anonymous Sessions], [Total Sessions])
		formatString: 0.00%
		displayFolder: 'Graph Page 1'
		lineageTag: 23ed0e49-ce43-4ee2-8423-9066388cd23a

	measure 'Percent Identified Sessions' = DIVIDE([Identified Sessions], [Total Sessions])
		formatString: 0.00%
		displayFolder: 'Graph Page 1'
		lineageTag: dfa8d5c5-0f00-40ff-a551-4ab2501da26b

	measure 'Avg Actions Anonymous Session' = CALCULATE([Avg Session Depth], KEEPFILTERS('public dim_session'[session_type] = "anonymous"))
		formatString: 0.00
		displayFolder: 'Graph Page 1'
		lineageTag: 2300df54-5277-4088-a061-9b68430573b3

	measure 'Avg Actions Identified Session' = CALCULATE([Avg Session Depth], KEEPFILTERS('public dim_session'[session_type] <> "anonymous"))
		formatString: 0.00
		displayFolder: 'Graph Page 1'
		lineageTag: 1ae9807a-3683-4b73-b784-a9942cad1328

	measure 'Sessions (Views 1-5)' = CALCULATE([Total Sessions], KEEPFILTERS('public dim_session'[total_views] >= 1), KEEPFILTERS('public dim_session'[total_views] <= 5))
		formatString: #,0
		displayFolder: 'Graph Page 2'
		lineageTag: dd845f63-7c97-462c-8bd5-5b77a71d4d5e

