	column segment_base
		dataType: string
		isHidden
		lineageTag: 857d9b5a-2982-410f-88f5-0a215d9a89f0
		summarizeBy: none
		sourceColumn: segment

		annotation SummarizationSetBy = Automatic

	column timeframe = [timeframe_base]
		dataType: string
		lineageTag: da81936a-b2b7-423f-8eb1-51871ede3f93
		summarizeBy: none
		sortByColumn: 'Timeframe Sort'

		annotation SummarizationSetBy = Automatic

	column 'Timeframe Sort' =
			SWITCH('public session_summary'[timeframe_base],
			    "Trước (gốc)", 1,
			    "Sau (có model)", 2,
			    3
			)
		dataType: int64
		formatString: 0
		lineageTag: da81936a-b2b7-423f-8eb1-51871ede3f92
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Conversion View Bucket (Fixed)' =
			SWITCH(TRUE(),
			    'public session_summary'[view_count] <= 10, FORMAT('public session_summary'[view_count], "0"),
			    'public session_summary'[view_count] <= 15, "11-15",
			    'public session_summary'[view_count] <= 20, "16-20",
			    "21+"
			)
		dataType: string
		lineageTag: ce0e8afc-ec4b-4b42-8261-c089f7618c71
		summarizeBy: none
		sortByColumn: 'Conversion View Bucket Sort'

		annotation SummarizationSetBy = Automatic

	column 'Conversion View Bucket Sort' =
			SWITCH(TRUE(),
			    'public session_summary'[view_count] <= 10, 'public session_summary'[view_count],
			    'public session_summary'[view_count] <= 15, 11,
			    'public session_summary'[view_count] <= 20, 16,
			    21
			)
		dataType: int64
		formatString: 0
		lineageTag: ce0e8afc-ec4b-4b42-8261-c089f7618c72
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column segment = [segment_base]
		dataType: string
		lineageTag: 857d9b5a-2982-410f-88f5-0a215d9a89f2
		summarizeBy: none
		sortByColumn: 'Segment Sort'

		annotation SummarizationSetBy = Automatic

	column 'Segment Sort' =
			SWITCH (
			    TRUE (),
			    'public session_summary'[has_purchase] && 'public session_summary'[view_count] >= 5, 1,
			    'public session_summary'[has_purchase], 3,
			    'public session_summary'[view_count] <= 1, 4,
			    2
			)
		dataType: int64
		formatString: 0
		lineageTag: 857d9b5a-2982-410f-88f5-0a215d9a89f1
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	partition 'public session_summary' = m
		mode: import
		source =
				let
				    Source = PostgreSQL.Database("recsys-sql-lytlong-e04a.b.aivencloud.com:22307", "defaultdb"),
				    public_session_summary = Source{[Schema="public",Item="session_summary"]}[Data]
				in
				    public_session_summary

